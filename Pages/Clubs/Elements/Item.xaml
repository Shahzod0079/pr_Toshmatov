<UserControl x:Class="pr_26_Toshmatov.Pages.Clubs.Elements.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:pr_26_Toshmatov.Pages.Clubs.Elements"
             mc:Ignorable="d" d:DesignWidth="800" Height="200">

    <Grid Margin="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10" Source="/Images/clubs-icon.png" />

        <Button Click="EditClub" Height="25" Content="Изменить" 
                VerticalAlignment="Top" Margin="10,95,10,5"
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" />

        <Button Click="DeleteClub" Height="25" Content="Удалить" 
                Margin="10,125,10,10"
                Background="#FFB22318" BorderBrush="#FFB22318" Foreground="White" 
                VerticalAlignment="Top" />

        <Grid Grid.Column="1" Margin="10,0,10,0" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Label Content="Наименование:" Margin="0,0,0,0" Height="26"/>
                <TextBox x:Name="club" Text="Наименование" Margin="0,5,0,10"
                         VerticalContentAlignment="Center" IsEnabled="False" Height="25" Width="120"/>

                <Label Content="Адрес:" Margin="0,0,0,0" Height="26"/>
                <TextBox x:Name="Address" Text="Адрес" Margin="0,5,0,0"
                         VerticalContentAlignment="Center" IsEnabled="False" Height="25" Width="120"/>
            </StackPanel>

            <!-- Правая колонка -->
            <StackPanel Grid.Column="1">
                <Label Content="Время работы:" Margin="0,0,0,0" Height="26"/>
                <TextBox x:Name="WorkTime" Text="Время работы" Margin="0,5,0,0"
                         VerticalAlignment="Top" Height="120"
                         VerticalContentAlignment="Top" 
                         IsEnabled="False" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>