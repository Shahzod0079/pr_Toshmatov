<UserControl x:Class="pr_26_Toshmatov.Pages.Clubs.Elements.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:pr_26_Toshmatov.Pages.Clubs.Elements"
             mc:Ignorable="d" d:DesignWidth="800" Height="176">
    <Grid Margin="10,10,449,10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10" Source="/Images/clubs-icon.png" />
        <Button Click="EditClub" Height="25" Content="Изменить" 
                VerticalAlignment="Top" Margin="10,95,10,0"
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" />
        <Button Click="DeleteClub" Content="Удалить" Margin="10,125,10,0"
                Background="#FFCDE1E1" BorderBrush="#FFCDE1E1" Foreground="White" Height="25" VerticalAlignment="Top" />

        <Grid Grid.Column="1" Height="156" VerticalAlignment="Center" Margin="0,0,-144,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="247*"/>
                <ColumnDefinition Width="187*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Наименование:" VerticalAlignment="Top" 
                   HorizontalAlignment="Left" Margin="10,10,0,0" Height="26" Width="96"/>
            <TextBox x:Name="Name" Text="Наименование" Margin="10,36,0,0"
                     VerticalContentAlignment="Center" IsEnabled="False" Height="25" VerticalAlignment="Top" HorizontalAlignment="Left" Width="96"/>

            <Label Content="Адрес:" VerticalAlignment="Center" 
                   HorizontalAlignment="Left" Margin="10,0,0,0" Height="26" Width="46"/>
            <TextBox x:Name="Address" Text="Адрес" 
                     VerticalAlignment="Top" Margin="10,92,0,0" Height="25"
                     VerticalContentAlignment="Center" IsEnabled="False" HorizontalAlignment="Left" Width="96"/>

            <Label Content="Время работы:" VerticalAlignment="Top" 
                   HorizontalAlignment="Left" Margin="127,10,0,0" Height="26" Width="91"/>
            <TextBox x:Name="WorkTime" Text="Время работы" 
                     VerticalAlignment="Top" Margin="129,36,0,0" Height="81"
                     VerticalContentAlignment="Top" 
                     IsEnabled="False" TextWrapping="Wrap" HorizontalAlignment="Left" Width="87"/>
        </Grid>
    </Grid>
</UserControl>
