<Page x:Class="pr_26_Toshmatov.Pages.Users.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr_26_Toshmatov.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Margin="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10" Source="/Images/icon-user.png" />

        <Button x:Name="BtnSave" Click="SaveUser" Height="25" Content="Добавить" 
                VerticalAlignment="Top" Margin="10,95,10,0"
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" />

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка -->
            <Label Content="ФИО:" VerticalAlignment="Top" 
                   HorizontalAlignment="Left" Margin="10,137,0,0"/>
            <TextBox x:Name="FIO" 
                     VerticalAlignment="Top" Margin="10,163,10,0" Height="25"
                     VerticalContentAlignment="Center" Grid.ColumnSpan="2"/>

            <Label Content="Дата аренды:" VerticalAlignment="Top" 
                   HorizontalAlignment="Left" Margin="10,9,0,0"/>
            <DatePicker x:Name="RentDate" 
                        VerticalAlignment="Top" Margin="10,36,10,0" Height="25"
                        VerticalContentAlignment="Center"/>

            <Label Content="Время аренды:" VerticalAlignment="Top" 
                   HorizontalAlignment="Left" Margin="10,66,0,0"/>
            <TextBox x:Name="RentTime" 
                     VerticalAlignment="Top" Margin="10,92,10,0" Height="25"
                     VerticalContentAlignment="Center" />

            <Label Content="Клуб:" VerticalAlignment="Top" 
       HorizontalAlignment="Left" Margin="10,66,0,0" Grid.Column="1"/>
            <ComboBox x:Name="ClubComboBox" 
          VerticalAlignment="Top" Margin="10,92,10,0" Height="25"
          DisplayMemberPath="Name" Grid.Column="1">
                <ComboBoxItem IsSelected="True" IsEnabled="True">Выберите...</ComboBoxItem>
            </ComboBox>

            <Label Content="Продолжительность (часов):" VerticalAlignment="Top" 
                   HorizontalAlignment="Left" Margin="10,10,0,0" Grid.Column="1"/>
            <TextBox x:Name="Duration" 
                     VerticalAlignment="Top" Margin="10,36,10,0" Height="25"
                     VerticalContentAlignment="Center" Grid.Column="1" 
                     TextWrapping="NoWrap" />
        </Grid>
    </Grid>
</Page>