<UserControl x:Class="pr_26_Toshmatov.Pages.Users.Elemets.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:pr_26_Toshmatov.Pages.Users.Elemets"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10,10,10,225"Margin="10,10,376,0" Background="White" Height="215" VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10" Source="/Images/icon-user.png" />
        <Button Click="BthAdd" Height="25" Content="Добавить" 
             VerticalAlignment="Top" Margin="10,95,10,0"
             Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" />
        <Button Click="BthDelet" Height="25" Content="Удалить" 
     VerticalAlignment="Top" Margin="10,134,10,0"
     Background="#FFB22318" Foreground="White" />

        <Grid Grid.Column="1" HorizontalAlignment="Left" Width="680">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="13*"/>
                <ColumnDefinition Width="55*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Дата аренды:" VerticalAlignment="Top" 
                HorizontalAlignment="Left" Margin="10,10,0,0" Height="26" Width="83"/>
            <DatePicker x:Name="RentDate"  Text="Наименование" 
                  VerticalAlignment="Top" Margin="10,36,0,0" Height="25"
                  VerticalContentAlignment="Center" IsEnabled="False" HorizontalAlignment="Left" Width="110"/>

            <Label Content="Время аренды:" VerticalAlignment="Top" 
                HorizontalAlignment="Left" Margin="10,66,0,0" Height="26" Width="92"/>
            <TextBox x:Name="Address" 
                  VerticalAlignment="Top" Margin="10,92,0,0" Height="25"
                  VerticalContentAlignment="Center" IsEnabled="False" HorizontalAlignment="Left" Width="110"/>

            <Label Content="Продолжительность:" VerticalAlignment="Top" 
                HorizontalAlignment="Left" Margin="0,10,0,0" Grid.Column="1" Height="26" Width="125"/>
            <TextBox x:Name="WorkTime" 
                  VerticalAlignment="Top" Margin="10,92,0,0"Margin="10,92,0,0" Height="25"
                  VerticalContentAlignment="Top" Grid.Column="1" 
                  IsEnabled="False" TextWrapping="Wrap" HorizontalAlignment="Left"HorizontalAlignment="Left" Width="152"/>
            <TextBox x:Name="WorkTime_Копировать" 
                VerticalAlignment="Top" Margin="10,155,0,0" Height="25"
                VerticalContentAlignment="Top" 
                IsEnabled="False" TextWrapping="Wrap" Grid.ColumnSpan="2" HorizontalAlignment="Left" Width="282"/>
            <Label Content="Клуб:" VerticalAlignment="Top" 
                HorizontalAlignment="Left" Margin="10,66,0,0" Grid.Column="1" Height="26" Width="39"/>
            <Label Content="ФИО:" VerticalAlignment="Top" 
                HorizontalAlignment="Center" Margin="0,129,0,0" Width="204" Height="26"/>
            <TextBox x:Name="WorkTime_Копировать1" 
                VerticalAlignment="Top" Margin="10,36,0,0" Height="25"
                VerticalContentAlignment="Top" Grid.Column="1" 
                IsEnabled="False" TextWrapping="Wrap" HorizontalAlignment="Left" Width="152"/>
        </Grid>
    </Grid>
</UserControl>
