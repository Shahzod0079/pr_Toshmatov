<Page x:Class="pr_26_Toshmatov.Pages.Users.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr_26_Toshmatov.Pages.Users"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid Margin="20" Background="#FFF0F0F0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" HorizontalAlignment="Left">
                <Label Content="Поиск по ФИО:" VerticalAlignment="Center"/>
                <TextBox x:Name="SearchBox" Width="200" Height="25" Margin="5" TextChanged="SearchBox_TextChanged"/>

                <Label Content="Сортировка:" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox x:Name="SortBox" Width="150" Height="25" Margin="5" SelectionChanged="SortBox_SelectionChanged">
                    <ComboBoxItem>По ФИО</ComboBoxItem>
                    <ComboBoxItem>По дате</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,0,0,50">
                <StackPanel x:Name="Parent"/>
            </ScrollViewer>

            <Button 
                x:Name="BthAdd"
                Click="AddUser"
                Height="25" 
                Content="Добавить" 
                VerticalAlignment="Bottom" 
                Margin="0,0,10,10" 
                HorizontalAlignment="Right" 
                Width="100" 
                Background="#FF46FD00" 
                BorderBrush="#FF46FD00" 
                Foreground="White" Grid.Row="1"/>
        </Grid>
    </Grid>
</Page>